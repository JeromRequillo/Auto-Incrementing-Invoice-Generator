; --- Initialization ---
#NoEnv
SendMode Input
SetWorkingDir %A_ScriptDir%

; I-load ang huling number mula sa settings.ini file
IniRead, current_num, settings.ini, Sequence, LastNumber, 46434

!F9::
    ; Mas malinis na paraan para sa padding (6 digits)
    formatted_num := Format("{:07}", current_num)
    
    invoice_string := "AAPI" . formatted_num . "S"
    
    ; Gamitin ang SendInput para mas mabilis at hindi ma-interrupt
    SendInput, %invoice_string%
    
    ; Notification (TrayTip para hindi sagabal sa gitna ng screen)
    TrayTip, Auto-Invoice, Sent: %invoice_string%, 1
    
    ; I-update ang number at i-save agad sa file
    current_num += 1
    IniWrite, %current_num%, settings.ini, Sequence, LastNumber
return

!F10::
    InputBox, NewNum, Update Sequence, Enter the next Invoice Number starting digit:, , 250, 150
    if !ErrorLevel
    {
        current_num := NewNum
        IniWrite, %current_num%, settings.ini, Sequence, LastNumber
        MsgBox, 64, Updated, Sequence is now set to: %current_num%, 2
    }
return
